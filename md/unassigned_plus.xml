<?xml version="1.0" encoding="utf-8"?>
<mdscript name="Unassigned_Plus" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
  <cues>

    <cue name="Init" version="1">
      <actions>
        <include_actions ref="DefaultConfig" />
        <remove_value name="$config" />
      </actions>
    </cue>

    <!-- Reads (or initialises) mod config from player.entity.$unassignedPlusConfig.
         Leaves a local $config reference; caller must <remove_value name="$config" />. -->
    <library name="DefaultConfig" purpose="include_actions" version="1">
      <actions>
        <do_if value="@player.entity.$unassignedPlusConfig == null">
          <set_value name="player.entity.$unassignedPlusConfig" exact="table[
            $hideOriginalTab = false,
          ]" />
        </do_if>
        <set_value name="$config" exact="player.entity.$unassignedPlusConfig" />
        <!-- forward-compat: fill keys added in later versions -->
        <do_if value="$config.$hideOriginalTab? == false">
          <set_value name="$config.$hideOriginalTab" exact="false" />
        </do_if>
        <do_if value="$config.$vanillaTabAlreadyHidden? == false">
          <set_value name="$config.$vanillaTabAlreadyHidden" exact="false" />
        </do_if>
      </actions>
    </library>

    <!-- *** Options menu *** -->

    <cue name="Register_Menu" instantiate="true" version="1">
      <conditions>
        <event_cue_signalled cue="md.Simple_Menu_API.Reloaded" />
      </conditions>
      <actions>
        <signal_cue_instantly cue="md.Simple_Menu_API.Register_Options_Menu"
          param="table[
            $id      = 'unassigned_plus_options',
            $columns = 12,
            $title   = {1972092421, 1},
            $onOpen  = Unassigned_Plus_Options_Menu,
          ]" />
      </actions>
    </cue>

    <cue name="Unassigned_Plus_Options_Menu" instantiate="true" version="1">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <include_actions ref="DefaultConfig" />
        <run_actions ref="md.Options_Helper.Add_Checkbox">
          <param name="id" value="'hideOriginalTab'" />
          <param name="col" value="1" />
          <param name="textColSpan" value="11" />
          <param name="text" value="{1972092421, 90001}" />
          <param name="data" value="$config" />
          <param name="active" value="$config.$vanillaTabAlreadyHidden != 1" />
          <param name="handle" value="Handle_Checkbox_Changed" />
        </run_actions>
        <remove_value name="$config" />
      </actions>
    </cue>

    <cue name="Handle_Checkbox_Changed" instantiate="true" version="1">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <debug_text text="'UnassignedPlus: Checkbox changed, id= %s, checked= %s' . [event.param.$echo.$valueId, event.param.$checked]" />
        <include_actions ref="DefaultConfig" />
        <set_value name="$resultTable" exact="$config" />
        <include_actions ref="md.Options_Helper.Process_Checkbox_Changed" />
        <raise_lua_event name="'UnassignedPlus.ConfigChanged'" />
        <remove_value name="$config" />
        <remove_value name="$resultTable" />
      </actions>
    </cue>

  </cues>
</mdscript>